---
const links = [
  { href: "/", label: "Home" },
  { href: "/gallery", label: "Gallery" }
];
---

<header class="site-shell site-header">
  <a class="site-brand" href="/">Gennei Snaps</a>
  <nav class="site-nav" aria-label="Primary">
    {
      links.map((link) => (
        <a href={link.href}>{link.label}</a>
      ))
    }
  </nav>
</header>
