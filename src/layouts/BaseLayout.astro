---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Gennei Snaps",
  description = "A quiet personal archive of city walks, flowers, and everyday photographs."
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  :root {
    --bg: #f2f2f0;
    --surface: rgba(255, 255, 255, 0.94);
    --surface-strong: #ffffff;
    --line: rgba(17, 17, 17, 0.12);
    --line-strong: rgba(17, 17, 17, 0.24);
    --text: #111111;
    --muted: #666666;
    --muted-soft: #8c8c8c;
    --shadow: 0 22px 50px rgba(17, 17, 17, 0.06);
    --page-width: min(1120px, calc(100vw - 2rem));
    --radius-lg: 32px;
    --radius-md: 22px;
    --radius-sm: 14px;
    --font-sans:
      "Helvetica Neue",
      Helvetica,
      "Hiragino Sans",
      "Hiragino Kaku Gothic ProN",
      "Yu Gothic",
      "Noto Sans JP",
      sans-serif;
  }

  * {
    box-sizing: border-box;
  }

  html {
    background:
      linear-gradient(180deg, rgba(255, 255, 255, 0.88), rgba(255, 255, 255, 0) 22rem),
      linear-gradient(180deg, #f7f7f5 0%, var(--bg) 100%);
    color: var(--text);
    font-family: var(--font-sans);
    scroll-behavior: smooth;
  }

  body {
    margin: 0;
    min-height: 100vh;
    background:
      radial-gradient(circle at top right, rgba(255, 255, 255, 0.92), transparent 28rem),
      linear-gradient(180deg, rgba(17, 17, 17, 0.015), rgba(17, 17, 17, 0));
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img {
    display: block;
    max-width: 100%;
  }

  .site-shell {
    width: var(--page-width);
    margin: 0 auto;
  }

  .site-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 1.4rem 0 1rem;
  }

  .site-brand {
    font-size: clamp(1.15rem, 2vw, 1.35rem);
    font-weight: 500;
    letter-spacing: 0.14em;
    text-transform: uppercase;
  }

  .site-nav {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-end;
  }

  .site-nav a {
    padding: 0.7rem 0.95rem;
    border: 1px solid transparent;
    border-radius: 999px;
    color: var(--muted);
    background: rgba(255, 255, 255, 0.3);
    font-size: 0.92rem;
    letter-spacing: 0.02em;
    transition:
      transform 180ms ease,
      border-color 180ms ease,
      background-color 180ms ease;
  }

  .site-nav a:hover,
  .site-nav a:focus-visible {
    transform: translateY(-1px);
    border-color: var(--line);
    background: rgba(255, 255, 255, 0.88);
  }

  main {
    padding: 0 0 4rem;
  }

  .section {
    position: relative;
    margin-top: 1.5rem;
    padding: clamp(1.2rem, 2vw, 1.85rem);
    border: 1px solid var(--line);
    border-radius: var(--radius-lg);
    background: var(--surface);
    box-shadow: var(--shadow);
  }

  .section-title,
  .page-title {
    margin: 0;
    font-weight: 500;
    line-height: 1;
    letter-spacing: -0.04em;
    text-wrap: balance;
  }

  .section-title {
    font-size: clamp(1.9rem, 4vw, 3.1rem);
  }

  .page-title {
    font-size: clamp(2.8rem, 7vw, 5.8rem);
  }

  .eyebrow {
    margin: 0 0 0.6rem;
    color: var(--muted);
    font-size: 0.74rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .lead {
    max-width: 64ch;
    margin: 0;
    color: var(--muted);
    font-size: 1rem;
    line-height: 1.75;
  }

  .photo-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1.35rem;
  }

  .photo-card {
    display: grid;
    gap: 0.95rem;
  }

  .photo-card-media,
  .hero-media,
  .detail-media {
    overflow: hidden;
    border-radius: var(--radius-md);
    border: 1px solid rgba(17, 17, 17, 0.08);
    background: var(--surface-strong);
  }

  .photo-card-media img,
  .hero-media img,
  .detail-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 280ms ease;
  }

  .photo-card a:hover img,
  .photo-card a:focus-visible img {
    transform: scale(1.02);
  }

  .photo-card-title {
    margin: 0;
    font-size: clamp(1.35rem, 2vw, 1.7rem);
    font-weight: 500;
    letter-spacing: -0.03em;
  }

  .meta-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    color: var(--muted);
    font-size: 0.9rem;
  }

  .tag-list,
  .category-list {
    display: flex;
    gap: 0.6rem;
    flex-wrap: wrap;
  }

  .pill {
    padding: 0.58rem 0.92rem;
    border-radius: 999px;
    border: 1px solid var(--line);
    background: rgba(255, 255, 255, 0.9);
    color: var(--muted);
    font-size: 0.88rem;
    transition:
      border-color 180ms ease,
      color 180ms ease,
      background-color 180ms ease,
      transform 180ms ease;
  }

  .pill:hover,
  .pill:focus-visible {
    transform: translateY(-1px);
    border-color: var(--line-strong);
    color: var(--text);
    background: var(--surface-strong);
  }

  .site-footer {
    padding: 0 0 2rem;
    color: var(--muted);
    font-size: 0.92rem;
  }

  .site-footer .section {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    align-items: center;
    flex-wrap: wrap;
  }

  @media (max-width: 900px) {
    .photo-grid {
      grid-template-columns: repeat(2, minmax(0, 1fr));
    }
  }

  @media (max-width: 720px) {
    .site-header {
      flex-direction: column;
      align-items: flex-start;
      padding-top: 1rem;
    }

    .site-nav {
      justify-content: flex-start;
    }
  }

  @media (max-width: 640px) {
    :root {
      --page-width: min(100vw - 1rem, 1120px);
      --radius-lg: 24px;
      --radius-md: 18px;
    }

    .section {
      margin-top: 1rem;
      padding: 1rem;
    }

    .photo-grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }

    .page-title {
      font-size: clamp(2.2rem, 14vw, 3.5rem);
    }

    .site-nav a,
    .pill {
      padding: 0.75rem 0.95rem;
    }
  }
</style>
