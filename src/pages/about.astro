---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import PageIntro from "../components/PageIntro.astro";
---

<BaseLayout
  title="About | Gennei Snaps"
  description="About Gennei Snaps and the simple workflow behind this static photo archive."
>
  <SiteHeader />
  <main>
    <PageIntro
      eyebrow="About"
      title="A small archive, kept on purpose"
      text="Gennei Snaps is a maintenance-friendly personal photography website built with Astro, local content files, and static deployment to GitHub Pages."
    />

    <section class="site-shell section about-grid">
      <div>
        <p class="eyebrow">Principles</p>
        <h2 class="section-title">Simple enough to keep for years</h2>
      </div>
      <div class="about-copy">
        <p class="lead">
          Photos and metadata live in the repository. There is no database, no CMS, and no server-side logic.
          Adding a new entry is only three steps: add optimized images, add one content file, then commit and deploy.
        </p>
        <p class="lead">
          Categories stay fixed to keep browsing predictable: night, city, flowers, and snap.
        </p>
      </div>
    </section>

    <section class="site-shell section workflow-grid">
      <div>
        <p class="eyebrow">Workflow</p>
        <h2 class="section-title">Adding a new photo</h2>
      </div>
      <ol class="workflow-list">
        <li>Add `thumb.jpg` and `hero.jpg` under `public/photos/&lt;slug&gt;/`.</li>
        <li>Add `src/content/photos/&lt;slug&gt;.md` with metadata and optional description.</li>
        <li>Commit the change. GitHub Actions validates the files and deploys the static site.</li>
      </ol>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .about-grid,
  .workflow-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.8fr) minmax(0, 1.2fr);
    gap: 1.1rem;
    align-items: start;
  }

  .about-copy {
    display: grid;
    gap: 1rem;
  }

  .workflow-list {
    margin: 0;
    padding-left: 1.25rem;
    color: var(--muted);
    line-height: 1.8;
  }

  .workflow-list li + li {
    margin-top: 0.55rem;
  }

  @media (max-width: 900px) {
    .about-grid,
    .workflow-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
