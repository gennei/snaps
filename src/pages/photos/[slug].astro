---
import { render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { categoryLabels, formatPhotoDate, getPhotos } from "../../lib/photos";

export async function getStaticPaths() {
  const photos = await getPhotos();

  return photos.map((photo) => ({
    params: { slug: photo.slug },
    props: { photo }
  }));
}

const { photo } = Astro.props;
const { Content } = await render(photo);
---

<BaseLayout
  title={`${photo.data.title} | Gennei Snaps`}
  description={photo.data.description ?? `Photo detail for ${photo.data.title}.`}
>
  <SiteHeader />
  <main>
    <section class="site-shell section detail-grid">
      <div class="detail-copy">
        <p class="eyebrow">{categoryLabels[photo.data.category]}</p>
        <h1 class="page-title">{photo.data.title}</h1>
        <div class="meta-row">
          <time datetime={photo.data.date.toISOString()}>
            {formatPhotoDate(photo.data.date)}
          </time>
          <span aria-hidden="true">·</span>
          <a class="pill" href={`/gallery?category=${photo.data.category}`}>
            {categoryLabels[photo.data.category]}
          </a>
        </div>
        {photo.data.tags && photo.data.tags.length > 0 && (
          <div class="tag-list">
            {photo.data.tags.map((tag) => <span class="pill">{tag}</span>)}
          </div>
        )}
        <div class="detail-body">
          <Content />
        </div>
      </div>

      <div class="detail-media">
        <img
          src={photo.data.image}
          alt={photo.data.title}
          width="2400"
          height="1600"
        />
      </div>
    </section>
  </main>
  <SiteFooter />
</BaseLayout>

<style>
  .detail-grid {
    display: grid;
    grid-template-columns: minmax(0, 0.85fr) minmax(0, 1.15fr);
    gap: 1.2rem;
    align-items: start;
  }

  .detail-copy {
    display: grid;
    gap: 1rem;
    position: sticky;
    top: 1rem;
  }

  .detail-body :global(p) {
    margin: 0;
    color: var(--muted);
    line-height: 1.8;
  }

  .detail-media {
    min-height: 620px;
  }

  @media (max-width: 980px) {
    .detail-grid {
      grid-template-columns: 1fr;
    }

    .detail-copy {
      position: static;
    }

    .detail-media {
      min-height: auto;
      aspect-ratio: 4 / 5;
    }
  }
</style>
